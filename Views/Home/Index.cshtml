@{
    ViewData["Title"] = "Customers Shoes | Adidop ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="Video-Slider relative w-full h-screen overflow-hidden mb-24 bg-zinc-900">

    <video autoplay loop muted playsinline class="absolute top-0 left-0 w-full h-full object-cover z-0">
        <source src="~/videos/videoBanner.mp4" type="video/mp4">
        Trình duyệt của bạn không hỗ trợ thẻ video.
    </video>

    <div class="relative z-10 flex flex-col items-center justify-center h-full bg-black/40 text-center px-4">
        <h1 class="text-white text-5xl md:text-7xl font-black uppercase tracking-tighter italic animate-pulse">
            Adidop Collection
        </h1>
        <p class="text-zinc-200 mt-3 text-xl max-w-lg">
            Sẵn sàng bứt phá cùng bộ sưu tập giày thể thao mới nhất mùa hè này.
        </p>
        <div class="mt-10 flex gap-4">
            <a href="#"
               class="bg-white text-black px-8 py-3 font-bold uppercase text-sm hover:bg-gray-200 transition-colors">
                Xem ngay
            </a>
            <a href="#"
               class="bg-transparent border-2 border-white text-white px-8 py-3 font-bold uppercase text-sm hover:bg-white hover:text-black transition-all">
                Tìm cửa hàng
            </a>
        </div>
    </div>

</div>
<div class="Customize-Shoes">
    Customize-Shoes
</div>
<div class="Add-Your-Image">
    Add-Your-Image
</div>
<div class="Blank-Canvas">
    Blank-Canvas
</div>
<div class="Customs-for-Kids">
    Customs-for-Kids
</div>
<div class="History mb-24">
    History
</div>

<div>
    <div class="subscribe-us h-[350px] bg-[#1d1f2e] flex flex-col justify-center items-center mb-24">
        <div class="flex justify-center items-center px-6 min-[480px]:px-0 mb-6 ">
            <div class="w-8 h-px bg-gray-700 "></div>
            <div class="uppercase mx-4 tracking-widest text-gray-400 font-bold text-xs text-center">
                Sign up and get a free shoe care kit.

            </div>
            <div class="w-8 h-px bg-gray-700"></div>
        </div>
        <div class="font-medium text-4xl text-white mb-6">Shoe Care Updates</div>
        <div class="ct-form">
            <div class="flex flex-col md:flex-row justify-center items-center gap-3">
                <div class="ct-form-item text-center">
                    <input type="email" placeholder="awtichcoder@gmail.com" class=" px-6 py-4 w-[350px] min-[480px]:max-w-full max-w-[80%] bg-inherit border-[1px] border-gray-700 outline-none text-white leading-5 hover:border-gray-300 duration-500 focus:border-gray-300 placeholder:uppercase placeholder:text-xs
                    placeholder:tracking-widest placeholder:font-semibold">
                </div>
                <div class="ct-form-item">
                    <button type="submit"
                            class="ct-button bg-white text-gray-900 w-max max-h-[54px] hover:bg-zinc-300">Subscribe</button>
                </div>
            </div>

        </div>
    </div>
